<%- include('../layouts/header') %>
    <%- include('../layouts/sidebar') %>
        <div class="page-header">
            <h2>Dashboard</h2>
            <p>Welcome, <%= user.employee_name %>
            </p>
        </div>
        <div class="stats-grid">
            <div class="stat-card blue">
                <div class="stat-icon"><i class="fas fa-building"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= branchCount %>
                    </h3>
                    <p>Total Branches</p>
                </div>
            </div>
            <div class="stat-card cyan">
                <div class="stat-icon"><i class="fas fa-chair"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= nonITCount %>
                    </h3>
                    <p>Non-IT Assets</p>
                </div>
            </div>
            <div class="stat-card yellow">
                <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= expiringCount %>
                    </h3>
                    <p>Expiring Agreements</p>
                </div>
            </div>
        </div>
        <% if (expiringAgreements && expiringAgreements.length> 0) { %>
            <div class="card" style="margin-top:20px;border-left:4px solid var(--warning);">
                <div class="card-header"><span class="card-title"><i class="fas fa-exclamation-triangle"
                            style="color:var(--warning);"></i> Expiring Agreements</span></div>
                <div class="table-wrapper">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Branch</th>
                                <th>Type</th>
                                <th>Vendor</th>
                                <th>End Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% expiringAgreements.forEach(ag=> { %><tr>
                                    <td>
                                        <%= ag.branch_code %>
                                    </td>
                                    <td>
                                        <%= ag.agreement_type || '-' %>
                                    </td>
                                    <td>
                                        <%= ag.vendor || '-' %>
                                    </td>
                                    <td>
                                        <%= ag.end_date ? new Date(ag.end_date).toLocaleDateString('en-IN') : '-' %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            <% } %>
                <%- include('../layouts/footer') %>