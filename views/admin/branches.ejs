<%- include('../layouts/header') %>
    <%- include('../layouts/sidebar') %>

        <div class="page-header">
            <h2>Branches</h2>
            <p>Manage all branch infrastructure</p>
        </div>

        <% if (success) { %>
            <div class="flash-message flash-success"><i class="fas fa-check-circle"></i>
                <%= success %>
            </div>
            <% } %>
                <% if (error) { %>
                    <div class="flash-message flash-error"><i class="fas fa-exclamation-circle"></i>
                        <%= error %>
                    </div>
                    <% } %>

                        <div class="action-bar">
                            <div class="search-box">
                                <i class="fas fa-search"></i>
                                <input type="text" id="searchBranch" placeholder="Search branches..."
                                    onkeyup="filterTable('branchTable', this.value)">
                            </div>
                            <button class="btn btn-primary" onclick="openModal('addBranchModal')"><i
                                    class="fas fa-plus"></i> Add Branch</button>
                        </div>

                        <div class="card">
                            <div class="table-wrapper">
                                <table class="data-table" id="branchTable">
                                    <thead>
                                        <tr>
                                            <th>Branch Code</th>
                                            <th>Branch Name</th>
                                            <th>Channel</th>
                                            <th>Contact</th>
                                            <th>ISP</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (branches.length===0) { %>
                                            <tr>
                                                <td colspan="7" class="empty-state"><i class="fas fa-building"></i>
                                                    <p>No branches found</p>
                                                </td>
                                            </tr>
                                            <% } %>
                                                <% branches.forEach(branch=> { %>
                                                    <tr>
                                                        <td><strong>
                                                                <%= branch.branch_code %>
                                                            </strong></td>
                                                        <td>
                                                            <%= branch.branch_name %>
                                                        </td>
                                                        <td>
                                                            <%= branch.channel_code || '-' %>
                                                        </td>
                                                        <td>
                                                            <%= branch.contact_number || '-' %>
                                                        </td>
                                                        <td>
                                                            <%= branch.isp || '-' %>
                                                        </td>
                                                        <td><span class="badge badge-<%= branch.status %>">
                                                                <%= branch.status %>
                                                            </span></td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline"
                                                                onclick="editBranch(<%- JSON.stringify(branch) %>)"><i
                                                                    class="fas fa-edit"></i></button>
                                                            <form action="/admin/branches/delete/<%= branch.id %>"
                                                                method="POST" style="display:inline;"
                                                                onsubmit="return confirmDelete('Delete this branch?')">
                                                                <button type="submit" class="btn btn-sm btn-danger"><i
                                                                        class="fas fa-trash"></i></button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Add Branch Modal -->
                        <div class="modal-overlay" id="addBranchModal">
                            <div class="modal">
                                <div class="modal-header">
                                    <h3>Add New Branch</h3>
                                    <button class="modal-close" onclick="closeModal('addBranchModal')">&times;</button>
                                </div>
                                <form action="/admin/branches" method="POST">
                                    <div class="form-row">
                                        <div class="form-group"><label>Branch Code *</label><input type="text"
                                                name="branch_code" class="form-control" required></div>
                                        <div class="form-group"><label>Branch Name *</label><input type="text"
                                                name="branch_name" class="form-control" required></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Channel Code</label><input type="text"
                                                name="channel_code" class="form-control"></div>
                                        <div class="form-group"><label>Contact Number</label><input type="text"
                                                name="contact_number" class="form-control"></div>
                                    </div>
                                    <div class="form-group"><label>Address</label><textarea name="address"
                                            class="form-control" rows="2"></textarea></div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Pincode</label><input type="text" name="pincode"
                                                class="form-control"></div>
                                        <div class="form-group"><label>ISP</label><input type="text" name="isp"
                                                class="form-control"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>IP Address</label><input type="text"
                                                name="ip_address" class="form-control"></div>
                                        <div class="form-group"><label>Circuit ID</label><input type="text"
                                                name="circuit_id" class="form-control"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Billing Account</label><input type="text"
                                                name="billing_account" class="form-control"></div>
                                        <div class="form-group"><label>ISP LC</label><input type="text" name="isp_lc"
                                                class="form-control"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Branch Opening Date</label><input type="date"
                                                name="branch_opening_date" class="form-control"></div>
                                        <div class="form-group"><label>KSEB Consumer No</label><input type="text"
                                                name="kseb_consumer_no" class="form-control"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Agreement Start</label><input type="date"
                                                name="agreement_start_date" class="form-control"></div>
                                        <div class="form-group"><label>Agreement End</label><input type="date"
                                                name="agreement_end_date" class="form-control"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Internet Activated</label><input type="date"
                                                name="internet_activated_date" class="form-control"></div>
                                        <div class="form-group"><label>Disconnected Date</label><input type="date"
                                                name="disconnected_date" class="form-control"></div>
                                    </div>
                                    <div class="form-group"><label>Status</label>
                                        <select name="status" class="form-control">
                                            <option value="active">Active</option>
                                            <option value="inactive">Inactive</option>
                                            <option value="closed">Closed</option>
                                        </select>
                                    </div>
                                    <div class="form-group"><label>Updates / Notes</label><textarea name="updates"
                                            class="form-control" rows="2"></textarea></div>
                                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save
                                        Branch</button>
                                </form>
                            </div>
                        </div>

                        <!-- Edit Branch Modal -->
                        <div class="modal-overlay" id="editBranchModal">
                            <div class="modal">
                                <div class="modal-header">
                                    <h3>Edit Branch</h3>
                                    <button class="modal-close" onclick="closeModal('editBranchModal')">&times;</button>
                                </div>
                                <form id="editBranchForm" method="POST">
                                    <div class="form-row">
                                        <div class="form-group"><label>Branch Code</label><input type="text"
                                                class="form-control" id="eb_branch_code" disabled></div>
                                        <div class="form-group"><label>Branch Name *</label><input type="text"
                                                name="branch_name" class="form-control" id="eb_branch_name" required>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Channel Code</label><input type="text"
                                                name="channel_code" class="form-control" id="eb_channel_code"></div>
                                        <div class="form-group"><label>Contact Number</label><input type="text"
                                                name="contact_number" class="form-control" id="eb_contact_number"></div>
                                    </div>
                                    <div class="form-group"><label>Address</label><textarea name="address"
                                            class="form-control" id="eb_address" rows="2"></textarea></div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Pincode</label><input type="text" name="pincode"
                                                class="form-control" id="eb_pincode"></div>
                                        <div class="form-group"><label>ISP</label><input type="text" name="isp"
                                                class="form-control" id="eb_isp"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>IP Address</label><input type="text"
                                                name="ip_address" class="form-control" id="eb_ip_address"></div>
                                        <div class="form-group"><label>Circuit ID</label><input type="text"
                                                name="circuit_id" class="form-control" id="eb_circuit_id"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Billing Account</label><input type="text"
                                                name="billing_account" class="form-control" id="eb_billing_account">
                                        </div>
                                        <div class="form-group"><label>ISP LC</label><input type="text" name="isp_lc"
                                                class="form-control" id="eb_isp_lc"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Branch Opening Date</label><input type="date"
                                                name="branch_opening_date" class="form-control"
                                                id="eb_branch_opening_date"></div>
                                        <div class="form-group"><label>KSEB Consumer No</label><input type="text"
                                                name="kseb_consumer_no" class="form-control" id="eb_kseb_consumer_no">
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Agreement Start</label><input type="date"
                                                name="agreement_start_date" class="form-control"
                                                id="eb_agreement_start_date"></div>
                                        <div class="form-group"><label>Agreement End</label><input type="date"
                                                name="agreement_end_date" class="form-control"
                                                id="eb_agreement_end_date"></div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group"><label>Internet Activated</label><input type="date"
                                                name="internet_activated_date" class="form-control"
                                                id="eb_internet_activated_date"></div>
                                        <div class="form-group"><label>Disconnected Date</label><input type="date"
                                                name="disconnected_date" class="form-control" id="eb_disconnected_date">
                                        </div>
                                    </div>
                                    <div class="form-group"><label>Status</label>
                                        <select name="status" class="form-control" id="eb_status">
                                            <option value="active">Active</option>
                                            <option value="inactive">Inactive</option>
                                            <option value="closed">Closed</option>
                                        </select>
                                    </div>
                                    <div class="form-group"><label>Updates / Notes</label><textarea name="updates"
                                            class="form-control" id="eb_updates" rows="2"></textarea></div>
                                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update
                                        Branch</button>
                                </form>
                            </div>
                        </div>

                        <script>
                            function openModal(id) { document.getElementById(id).classList.add('active'); }
                            function closeModal(id) { document.getElementById(id).classList.remove('active'); }
                            function formatDate(d) { return d ? d.substring(0, 10) : ''; }
                            function editBranch(b) {
                                document.getElementById('editBranchForm').action = '/admin/branches/update/' + b.id;
                                document.getElementById('eb_branch_code').value = b.branch_code;
                                document.getElementById('eb_branch_name').value = b.branch_name || '';
                                document.getElementById('eb_channel_code').value = b.channel_code || '';
                                document.getElementById('eb_contact_number').value = b.contact_number || '';
                                document.getElementById('eb_address').value = b.address || '';
                                document.getElementById('eb_pincode').value = b.pincode || '';
                                document.getElementById('eb_isp').value = b.isp || '';
                                document.getElementById('eb_ip_address').value = b.ip_address || '';
                                document.getElementById('eb_circuit_id').value = b.circuit_id || '';
                                document.getElementById('eb_billing_account').value = b.billing_account || '';
                                document.getElementById('eb_isp_lc').value = b.isp_lc || '';
                                document.getElementById('eb_branch_opening_date').value = formatDate(b.branch_opening_date);
                                document.getElementById('eb_kseb_consumer_no').value = b.kseb_consumer_no || '';
                                document.getElementById('eb_agreement_start_date').value = formatDate(b.agreement_start_date);
                                document.getElementById('eb_agreement_end_date').value = formatDate(b.agreement_end_date);
                                document.getElementById('eb_internet_activated_date').value = formatDate(b.internet_activated_date);
                                document.getElementById('eb_disconnected_date').value = formatDate(b.disconnected_date);
                                document.getElementById('eb_status').value = b.status;
                                document.getElementById('eb_updates').value = b.updates || '';
                                openModal('editBranchModal');
                            }
                            function filterTable(tableId, query) {
                                const table = document.getElementById(tableId);
                                const rows = table.querySelectorAll('tbody tr');
                                query = query.toLowerCase();
                                rows.forEach(row => {
                                    row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
                                });
                            }
                        </script>

                        <%- include('../layouts/footer') %>