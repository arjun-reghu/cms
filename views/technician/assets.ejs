<%- include('../layouts/header') %>
    <%- include('../layouts/sidebar') %>
        <div class="page-header">
            <h2>Assets</h2>
            <p>Manage IT and Non-IT assets</p>
        </div>
        <% if (success) { %>
            <div class="flash-message flash-success"><i class="fas fa-check-circle"></i>
                <%= success %>
            </div>
            <% } %>
                <% if (error) { %>
                    <div class="flash-message flash-error"><i class="fas fa-exclamation-circle"></i>
                        <%= error %>
                    </div>
                    <% } %>
                        <div class="action-bar">
                            <div class="filter-group">
                                <a href="/technician/assets?view=branch"
                                    class="btn <%= view === 'branch' ? 'btn-primary' : 'btn-outline' %>">Branch
                                    Assets</a>
                                <a href="/technician/assets?view=catalogue"
                                    class="btn <%= view === 'catalogue' ? 'btn-primary' : 'btn-outline' %>">Catalogue</a>
                                <a href="/technician/assets?view=employee"
                                    class="btn <%= view === 'employee' ? 'btn-primary' : 'btn-outline' %>">Employee
                                    Assets</a>
                                <a href="/technician/assets?view=stock"
                                    class="btn <%= view === 'stock' ? 'btn-primary' : 'btn-outline' %>">Stock</a>
                            </div>
                            <% if (view==='branch' || view==='stock' ) { %><button class="btn btn-primary"
                                    onclick="openModal('addAssetModal')"><i class="fas fa-plus"></i> Add Asset</button>
                                <% } %>
                        </div>
                        <% if (view==='catalogue' ) { %>
                            <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr);">
                                <div class="card">
                                    <div class="card-header"><span class="card-title">Items</span><button
                                            class="btn btn-sm btn-primary" onclick="openModal('addItemModal')"><i
                                                class="fas fa-plus"></i></button></div>
                                    <div class="table-wrapper">
                                        <table class="data-table">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>Code</th>
                                                    <th>Type</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% items.forEach(i=> { %><tr>
                                                        <td>
                                                            <%= i.item_name %>
                                                        </td>
                                                        <td>
                                                            <%= i.item_code %>
                                                        </td>
                                                        <td>
                                                            <%= i.asset_type %>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% if(!items.length) { %>
                                                            <tr>
                                                                <td colspan="3"
                                                                    style="color:var(--text-muted);text-align:center;">
                                                                    No items</td>
                                                            </tr>
                                                            <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="card">
                                    <div class="card-header"><span class="card-title">Makes</span><button
                                            class="btn btn-sm btn-primary" onclick="openModal('addMakeModal')"><i
                                                class="fas fa-plus"></i></button></div>
                                    <div class="table-wrapper">
                                        <table class="data-table">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% makes.forEach(m=> { %><tr>
                                                        <td>
                                                            <%= m.make_name %>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% if(!makes.length) { %>
                                                            <tr>
                                                                <td style="color:var(--text-muted);text-align:center;">
                                                                    No makes</td>
                                                            </tr>
                                                            <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="card">
                                    <div class="card-header"><span class="card-title">Models</span><button
                                            class="btn btn-sm btn-primary" onclick="openModal('addModelModal')"><i
                                                class="fas fa-plus"></i></button></div>
                                    <div class="table-wrapper">
                                        <table class="data-table">
                                            <thead>
                                                <tr>
                                                    <th>Model</th>
                                                    <th>Make</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% models.forEach(m=> { %><tr>
                                                        <td>
                                                            <%= m.model_name %>
                                                        </td>
                                                        <td>
                                                            <%= m.make_name %>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                        <% if(!models.length) { %>
                                                            <tr>
                                                                <td colspan="2"
                                                                    style="color:var(--text-muted);text-align:center;">
                                                                    No models</td>
                                                            </tr>
                                                            <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <% } else if (view==='employee' ) { %>
                                <div class="card">
                                    <div class="card-header"><span class="card-title">Assign Asset</span></div>
                                    <form action="/technician/assets/assign" method="POST">
                                        <div class="form-row">
                                            <div class="form-group"><label>Employee</label><select name="employee_code"
                                                    class="form-control" required>
                                                    <option value="">Select</option>
                                                    <% employees.forEach(e=> { %><option value="<%= e.employee_code %>">
                                                            <%= e.employee_code %> - <%= e.employee_name %>
                                                        </option>
                                                        <% }) %>
                                                </select></div>
                                            <div class="form-group"><label>Asset (Stock)</label><select name="asset_id"
                                                    class="form-control" required>
                                                    <option value="">Select</option>
                                                    <% assets.filter(a=> a.status === 'stock').forEach(a => { %><option
                                                            value="<%= a.id %>">
                                                            <%= a.asset_code %>
                                                        </option>
                                                        <% }) %>
                                                </select></div>
                                            <div class="form-group"><label>Date</label><input type="date"
                                                    name="assigned_date" class="form-control"
                                                    value="<%= new Date().toISOString().substring(0,10) %>"></div>
                                        </div>
                                        <div class="form-group"><label>Remarks</label><input type="text" name="remarks"
                                                class="form-control"></div>
                                        <button type="submit" class="btn btn-success"><i class="fas fa-link"></i>
                                            Assign</button>
                                    </form>
                                </div>
                                <% } else { %>
                                    <div class="card">
                                        <div class="action-bar" style="margin-bottom:0;">
                                            <div class="search-box"><i class="fas fa-search"></i><input type="text"
                                                    placeholder="Search..."
                                                    onkeyup="filterTable('assetTable', this.value)"></div>
                                        </div>
                                        <div class="table-wrapper" style="margin-top:16px;">
                                            <table class="data-table" id="assetTable">
                                                <thead>
                                                    <tr>
                                                        <th>Asset Code</th>
                                                        <th>Category</th>
                                                        <th>Make</th>
                                                        <th>Model</th>
                                                        <th>Serial No</th>
                                                        <th>Branch</th>
                                                        <th>Type</th>
                                                        <th>Status</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% let fa=view==='stock' ? assets.filter(a=> a.status === 'stock') :
                                                        assets; %>
                                                        <% fa.forEach(a=> { %>
                                                            <tr>
                                                                <td><strong>
                                                                        <%= a.asset_code %>
                                                                    </strong></td>
                                                                <td>
                                                                    <%= a.item_name || '-' %>
                                                                </td>
                                                                <td>
                                                                    <%= a.make_name || '-' %>
                                                                </td>
                                                                <td>
                                                                    <%= a.model_name || '-' %>
                                                                </td>
                                                                <td>
                                                                    <%= a.serial_number || '-' %>
                                                                </td>
                                                                <td>
                                                                    <%= a.branch_name || '-' %>
                                                                </td>
                                                                <td>
                                                                    <%= a.asset_type %>
                                                                </td>
                                                                <td><span class="badge badge-<%= a.status %>">
                                                                        <%= a.status %>
                                                                    </span></td>
                                                                <td>
                                                                    <button class="btn btn-sm btn-outline"
                                                                        onclick="editAsset(<%- JSON.stringify(a) %>)"><i
                                                                            class="fas fa-edit"></i></button>
                                                                    <button class="btn btn-sm btn-warning"
                                                                        onclick="transferAsset(<%- JSON.stringify(a) %>)"><i
                                                                            class="fas fa-exchange-alt"></i></button>
                                                                    <form action="/technician/assets/delete/<%= a.id %>"
                                                                        method="POST" style="display:inline;"
                                                                        onsubmit="return confirmDelete()"><button
                                                                            type="submit"
                                                                            class="btn btn-sm btn-danger"><i
                                                                                class="fas fa-trash"></i></button>
                                                                    </form>
                                                                </td>
                                                            </tr>
                                                            <% }) %>
                                                                <% if (!fa.length) { %>
                                                                    <tr>
                                                                        <td colspan="9" class="empty-state">
                                                                            <p>No assets</p>
                                                                        </td>
                                                                    </tr>
                                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    <% } %>
                                        <!-- Modals -->
                                        <div class="modal-overlay" id="addAssetModal">
                                            <div class="modal">
                                                <div class="modal-header">
                                                    <h3>Add Asset</h3><button class="modal-close"
                                                        onclick="closeModal('addAssetModal')">&times;</button>
                                                </div>
                                                <form action="/technician/assets" method="POST">
                                                    <div class="form-row">
                                                        <div class="form-group"><label>Asset Code *</label><input
                                                                type="text" name="asset_code" class="form-control"
                                                                required></div>
                                                        <div class="form-group"><label>Type *</label><select
                                                                name="asset_type" class="form-control" required>
                                                                <option value="IT">IT</option>
                                                                <option value="NON_IT">Non-IT</option>
                                                            </select></div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="form-group"><label>Category</label><select
                                                                name="item_id" class="form-control">
                                                                <option value="">Select</option>
                                                                <% items.forEach(i=> { %><option value="<%= i.id %>">
                                                                        <%= i.item_name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                        <div class="form-group"><label>Branch</label><select
                                                                name="branch_code" class="form-control">
                                                                <option value="">Select</option>
                                                                <% branches.forEach(b=> { %><option
                                                                        value="<%= b.branch_code %>">
                                                                        <%= b.branch_code %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="form-group"><label>Make</label><select
                                                                name="make_id" class="form-control">
                                                                <option value="">Select</option>
                                                                <% makes.forEach(m=> { %><option value="<%= m.id %>">
                                                                        <%= m.make_name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                        <div class="form-group"><label>Model</label><select
                                                                name="model_id" class="form-control">
                                                                <option value="">Select</option>
                                                                <% models.forEach(m=> { %><option value="<%= m.id %>">
                                                                        <%= m.model_name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="form-group"><label>Serial No</label><input
                                                                type="text" name="serial_number" class="form-control">
                                                        </div>
                                                        <div class="form-group"><label>Count</label><input type="number"
                                                                name="count" class="form-control" value="1" min="1">
                                                        </div>
                                                    </div>
                                                    <div class="form-group"><label>Status</label><select name="status"
                                                            class="form-control">
                                                            <option value="stock">Stock</option>
                                                            <option value="assigned">Assigned</option>
                                                            <option value="scrap">Scrap</option>
                                                        </select></div>
                                                    <button type="submit" class="btn btn-primary"><i
                                                            class="fas fa-save"></i> Save</button>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="modal-overlay" id="editAssetModal">
                                            <div class="modal">
                                                <div class="modal-header">
                                                    <h3>Edit Asset</h3><button class="modal-close"
                                                        onclick="closeModal('editAssetModal')">&times;</button>
                                                </div>
                                                <form id="editAssetForm" method="POST">
                                                    <div class="form-row">
                                                        <div class="form-group"><label>Asset Code</label><input
                                                                type="text" class="form-control" id="ea_code" disabled>
                                                        </div>
                                                        <div class="form-group"><label>Type</label><select
                                                                name="asset_type" class="form-control" id="ea_type">
                                                                <option value="IT">IT</option>
                                                                <option value="NON_IT">Non-IT</option>
                                                            </select></div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="form-group"><label>Category</label><select
                                                                name="item_id" class="form-control" id="ea_item">
                                                                <option value="">Select</option>
                                                                <% items.forEach(i=> { %><option value="<%= i.id %>">
                                                                        <%= i.item_name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                        <div class="form-group"><label>Branch</label><select
                                                                name="branch_code" class="form-control" id="ea_branch">
                                                                <option value="">Select</option>
                                                                <% branches.forEach(b=> { %><option
                                                                        value="<%= b.branch_code %>">
                                                                        <%= b.branch_code %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="form-group"><label>Make</label><select
                                                                name="make_id" class="form-control" id="ea_make">
                                                                <option value="">Select</option>
                                                                <% makes.forEach(m=> { %><option value="<%= m.id %>">
                                                                        <%= m.make_name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                        <div class="form-group"><label>Model</label><select
                                                                name="model_id" class="form-control" id="ea_model">
                                                                <option value="">Select</option>
                                                                <% models.forEach(m=> { %><option value="<%= m.id %>">
                                                                        <%= m.model_name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select></div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="form-group"><label>Serial No</label><input
                                                                type="text" name="serial_number" class="form-control"
                                                                id="ea_serial"></div>
                                                        <div class="form-group"><label>Count</label><input type="number"
                                                                name="count" class="form-control" id="ea_count" min="1">
                                                        </div>
                                                    </div>
                                                    <div class="form-group"><label>Status</label><select name="status"
                                                            class="form-control" id="ea_status">
                                                            <option value="stock">Stock</option>
                                                            <option value="assigned">Assigned</option>
                                                            <option value="scrap">Scrap</option>
                                                        </select></div>
                                                    <button type="submit" class="btn btn-primary"><i
                                                            class="fas fa-save"></i> Update</button>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="modal-overlay" id="transferModal">
                                            <div class="modal">
                                                <div class="modal-header">
                                                    <h3>Transfer Asset</h3><button class="modal-close"
                                                        onclick="closeModal('transferModal')">&times;</button>
                                                </div>
                                                <form action="/technician/assets/transfer" method="POST"><input
                                                        type="hidden" name="asset_id" id="tr_id"><input type="hidden"
                                                        name="from_branch" id="tr_from">
                                                    <div class="form-group"><label>Asset</label><input type="text"
                                                            class="form-control" id="tr_code" disabled></div>
                                                    <div class="form-group"><label>From</label><input type="text"
                                                            class="form-control" id="tr_from_display" disabled></div>
                                                    <div class="form-group"><label>To Branch *</label><select
                                                            name="to_branch" class="form-control" required>
                                                            <option value="">Select</option>
                                                            <% branches.forEach(b=> { %><option
                                                                    value="<%= b.branch_code %>">
                                                                    <%= b.branch_code %> - <%= b.branch_name %>
                                                                </option>
                                                                <% }) %>
                                                        </select></div>
                                                    <div class="form-group"><label>Remarks</label><input type="text"
                                                            name="remarks" class="form-control"></div>
                                                    <button type="submit" class="btn btn-warning"><i
                                                            class="fas fa-exchange-alt"></i> Transfer</button>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="modal-overlay" id="addItemModal">
                                            <div class="modal">
                                                <div class="modal-header">
                                                    <h3>Add Item</h3><button class="modal-close"
                                                        onclick="closeModal('addItemModal')">&times;</button>
                                                </div>
                                                <form action="/technician/assets/item" method="POST">
                                                    <div class="form-group"><label>Name *</label><input type="text"
                                                            name="item_name" class="form-control" required></div>
                                                    <div class="form-group"><label>Code *</label><input type="text"
                                                            name="item_code" class="form-control" required></div>
                                                    <div class="form-group"><label>Type *</label><select
                                                            name="asset_type" class="form-control" required>
                                                            <option value="IT">IT</option>
                                                            <option value="NON_IT">Non-IT</option>
                                                        </select></div><button type="submit" class="btn btn-primary"><i
                                                            class="fas fa-save"></i> Save</button>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="modal-overlay" id="addMakeModal">
                                            <div class="modal">
                                                <div class="modal-header">
                                                    <h3>Add Make</h3><button class="modal-close"
                                                        onclick="closeModal('addMakeModal')">&times;</button>
                                                </div>
                                                <form action="/technician/assets/make" method="POST">
                                                    <div class="form-group"><label>Name *</label><input type="text"
                                                            name="make_name" class="form-control" required></div><button
                                                        type="submit" class="btn btn-primary"><i
                                                            class="fas fa-save"></i> Save</button>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="modal-overlay" id="addModelModal">
                                            <div class="modal">
                                                <div class="modal-header">
                                                    <h3>Add Model</h3><button class="modal-close"
                                                        onclick="closeModal('addModelModal')">&times;</button>
                                                </div>
                                                <form action="/technician/assets/model" method="POST">
                                                    <div class="form-group"><label>Make *</label><select name="make_id"
                                                            class="form-control" required>
                                                            <option value="">Select</option>
                                                            <% makes.forEach(m=> { %><option value="<%= m.id %>">
                                                                    <%= m.make_name %>
                                                                </option>
                                                                <% }) %>
                                                        </select></div>
                                                    <div class="form-group"><label>Model *</label><input type="text"
                                                            name="model_name" class="form-control" required></div>
                                                    <button type="submit" class="btn btn-primary"><i
                                                            class="fas fa-save"></i> Save</button>
                                                </form>
                                            </div>
                                        </div>
                                        <script>
                                            function openModal(id) { document.getElementById(id).classList.add('active'); }
                                            function closeModal(id) { document.getElementById(id).classList.remove('active'); }
                                            function editAsset(a) { document.getElementById('editAssetForm').action = '/technician/assets/update/' + a.id; document.getElementById('ea_code').value = a.asset_code; document.getElementById('ea_type').value = a.asset_type; document.getElementById('ea_item').value = a.item_id || ''; document.getElementById('ea_branch').value = a.branch_code || ''; document.getElementById('ea_make').value = a.make_id || ''; document.getElementById('ea_model').value = a.model_id || ''; document.getElementById('ea_serial').value = a.serial_number || ''; document.getElementById('ea_count').value = a.count || 1; document.getElementById('ea_status').value = a.status; openModal('editAssetModal'); }
                                            function transferAsset(a) { document.getElementById('tr_id').value = a.id; document.getElementById('tr_code').value = a.asset_code; document.getElementById('tr_from').value = a.branch_code || ''; document.getElementById('tr_from_display').value = a.branch_code ? a.branch_code + ' - ' + (a.branch_name || '') : 'N/A'; openModal('transferModal'); }
                                            function filterTable(t, q) { document.getElementById(t).querySelectorAll('tbody tr').forEach(r => { r.style.display = r.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none' }); }
                                        </script>
                                        <%- include('../layouts/footer') %>