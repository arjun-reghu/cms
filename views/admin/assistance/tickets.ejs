<%- include('../../layouts/header') %>
    <%- include('../../layouts/sidebar') %>

        <div class="page-header">
            <h2>Assistance Tickets</h2>
            <p>Manage onboarding and offboarding tickets</p>
        </div>

        <% if (success) { %>
            <div class="flash-message flash-success"><i class="fas fa-check-circle"></i>
                <%= success %>
            </div>
            <% } %>
                <% if (error) { %>
                    <div class="flash-message flash-error"><i class="fas fa-exclamation-circle"></i>
                        <%= error %>
                    </div>
                    <% } %>

                        <div class="action-bar">
                            <div class="search-box"><i class="fas fa-search"></i><input type="text"
                                    placeholder="Search tickets..." onkeyup="filterTable('ticketTable', this.value)">
                            </div>
                        </div>

                        <div class="card">
                            <div class="table-wrapper">
                                <table class="data-table" id="ticketTable">
                                    <thead>
                                        <tr>
                                            <th>Ticket Code</th>
                                            <th>Type</th>
                                            <th>Created By</th>
                                            <th>Status</th>
                                            <th>Created At</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (tickets.length===0) { %>
                                            <tr>
                                                <td colspan="6" class="empty-state"><i class="fas fa-ticket-alt"></i>
                                                    <p>No open tickets</p>
                                                </td>
                                            </tr>
                                            <% } %>
                                                <% tickets.forEach(t=> { %>
                                                    <tr>
                                                        <td><strong>
                                                                <%= t.ticket_code %>
                                                            </strong></td>
                                                        <td><span
                                                                class="badge badge-<%= t.type === 'onboarding' ? 'active' : 'inactive' %>">
                                                                <%= t.type %>
                                                            </span></td>
                                                        <td>
                                                            <%= t.created_by_name || '-' %>
                                                        </td>
                                                        <td><span class="badge badge-<%= t.status %>">
                                                                <%= t.status %>
                                                            </span></td>
                                                        <td>
                                                            <%= t.created_at ? new
                                                                Date(t.created_at).toLocaleDateString('en-IN') : '-' %>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline"
                                                                onclick="viewTicket('<%= t.ticket_code %>')"><i
                                                                    class="fas fa-eye"></i></button>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <script>
                            function filterTable(tableId, query) {
                                const rows = document.getElementById(tableId).querySelectorAll('tbody tr');
                                query = query.toLowerCase();
                                rows.forEach(row => { row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none'; });
                            }
                            function viewTicket(code) { alert('Ticket details for ' + code); }
                        </script>

                        <%- include('../../layouts/footer') %>