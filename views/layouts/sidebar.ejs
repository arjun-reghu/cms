<% const roleId=user.role_id; const basePath=roleId===1 ? '/admin' : roleId===2 ? '/hr' : roleId===3 ? '/technician' :
    roleId===4 ? '/auditor' : roleId===5 ? '/admin-team' : '' ; const currentPath=typeof currentPage !=='undefined' ?
    currentPage : '' ; %>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-menu">
            <!-- Home / Dashboard -->
            <a href="<%= basePath %>/dashboard" class="sidebar-link <%= currentPath === 'dashboard' ? 'active' : '' %>">
                <i class="fas fa-home"></i>
                <span>Home</span>
            </a>

            <!-- Branches -->
            <% if ([1, 3, 4, 5].includes(roleId)) { %>
                <a href="<%= basePath %>/branches"
                    class="sidebar-link <%= currentPath === 'branches' ? 'active' : '' %>">
                    <i class="fas fa-building"></i>
                    <span>Branches</span>
                </a>
                <% } %>

                    <!-- Employees -->
                    <% if ([1, 2, 3, 4].includes(roleId)) { %>
                        <a href="<%= basePath %>/employees"
                            class="sidebar-link <%= currentPath === 'employees' ? 'active' : '' %>">
                            <i class="fas fa-users"></i>
                            <span>Employees</span>
                        </a>
                        <% } %>

                            <!-- Assets -->
                            <% if ([1, 3, 4, 5].includes(roleId)) { %>
                                <div
                                    class="sidebar-dropdown <%= ['assets', 'branch-assets', 'asset-catalogue', 'asset-dashboard', 'employee-assets', 'stock'].includes(currentPath) ? 'open' : '' %>">
                                    <a href="#" class="sidebar-link dropdown-toggle">
                                        <i class="fas fa-box"></i>
                                        <span>Assets</span>
                                        <i class="fas fa-chevron-down dropdown-arrow"></i>
                                    </a>
                                    <div class="dropdown-menu">
                                        <a href="<%= basePath %>/assets?view=dashboard"
                                            class="sidebar-sublink <%= currentPath === 'asset-dashboard' ? 'active' : '' %>">
                                            <span>Dashboard</span>
                                        </a>
                                        <a href="<%= basePath %>/assets?view=branch"
                                            class="sidebar-sublink <%= currentPath === 'branch-assets' ? 'active' : '' %>">
                                            <span>Branch Assets</span>
                                        </a>
                                        <% if ([1, 3].includes(roleId)) { %>
                                            <a href="<%= basePath %>/assets?view=employee"
                                                class="sidebar-sublink <%= currentPath === 'employee-assets' ? 'active' : '' %>">
                                                <span>Employee Assets</span>
                                            </a>
                                            <% } %>
                                                <a href="<%= basePath %>/assets?view=stock"
                                                    class="sidebar-sublink <%= currentPath === 'stock' ? 'active' : '' %>">
                                                    <span>Stock</span>
                                                </a>
                                                <a href="<%= basePath %>/assets?view=catalogue"
                                                    class="sidebar-sublink <%= currentPath === 'asset-catalogue' ? 'active' : '' %>">
                                                    <span>Catalogue</span>
                                                </a>
                                    </div>
                                </div>
                                <% } %>

                                    <!-- Assistance -->
                                    <% if ([1, 2, 3].includes(roleId)) { %>
                                        <div
                                            class="sidebar-dropdown <%= ['tickets', 'history'].includes(currentPath) ? 'open' : '' %>">
                                            <a href="#" class="sidebar-link dropdown-toggle">
                                                <i class="fas fa-headset"></i>
                                                <span>Assistance</span>
                                                <i class="fas fa-chevron-down dropdown-arrow"></i>
                                            </a>
                                            <div class="dropdown-menu">
                                                <a href="<%= basePath %>/assistance/tickets"
                                                    class="sidebar-sublink <%= currentPath === 'tickets' ? 'active' : '' %>">
                                                    <span>Create Tickets</span>
                                                </a>
                                                <a href="<%= basePath %>/assistance/history"
                                                    class="sidebar-sublink <%= currentPath === 'history' ? 'active' : '' %>">
                                                    <span>History</span>
                                                </a>
                                            </div>
                                        </div>
                                        <% } %>

                                            <!-- Auditor History -->
                                            <% if (roleId===4) { %>
                                                <a href="<%= basePath %>/history"
                                                    class="sidebar-link <%= currentPath === 'history' ? 'active' : '' %>">
                                                    <i class="fas fa-clock-rotate-left"></i>
                                                    <span>History</span>
                                                </a>
                                                <% } %>

                                                    <!-- Users (Admin only) -->
                                                    <% if (roleId===1) { %>
                                                        <a href="<%= basePath %>/users"
                                                            class="sidebar-link <%= currentPath === 'users' ? 'active' : '' %>">
                                                            <i class="fas fa-user-cog"></i>
                                                            <span>Users</span>
                                                        </a>
                                                        <% } %>

                                                            <!-- Reports (Admin only) -->
                                                            <% if (roleId===1) { %>
                                                                <a href="<%= basePath %>/reports"
                                                                    class="sidebar-link <%= currentPath === 'reports' ? 'active' : '' %>">
                                                                    <i class="fas fa-chart-bar"></i>
                                                                    <span>Reports</span>
                                                                </a>
                                                                <% } %>

                                                                    <!-- Agreements (Admin & AdminTeam) -->
                                                                    <% if ([1, 5].includes(roleId)) { %>
                                                                        <a href="<%= basePath %>/agreements"
                                                                            class="sidebar-link <%= currentPath === 'agreements' ? 'active' : '' %>">
                                                                            <i class="fas fa-file-contract"></i>
                                                                            <span>Agreements</span>
                                                                        </a>
                                                                        <% } %>
        </div>

        <!-- Logout -->
        <div class="sidebar-footer">
            <a href="/logout" class="sidebar-link logout-link">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content" id="mainContent">