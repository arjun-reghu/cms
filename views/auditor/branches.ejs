<%- include('../layouts/header') %>
    <%- include('../layouts/sidebar') %>
        <div class="page-header">
            <h2>Branches</h2>
            <p>View branch records (read-only)</p>
        </div>
        <div class="action-bar">
            <div class="search-box"><i class="fas fa-search"></i><input type="text" placeholder="Search..."
                    onkeyup="filterTable('branchTable', this.value)"></div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="data-table" id="branchTable">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Channel</th>
                            <th>Contact</th>
                            <th>ISP</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (branches.length===0) { %>
                            <tr>
                                <td colspan="6" class="empty-state">
                                    <p>No branches</p>
                                </td>
                            </tr>
                            <% } %>
                                <% branches.forEach(b=> { %><tr>
                                        <td><strong>
                                                <%= b.branch_code %>
                                            </strong></td>
                                        <td>
                                            <%= b.branch_name %>
                                        </td>
                                        <td>
                                            <%= b.channel_code || '-' %>
                                        </td>
                                        <td>
                                            <%= b.contact_number || '-' %>
                                        </td>
                                        <td>
                                            <%= b.isp || '-' %>
                                        </td>
                                        <td><span class="badge badge-<%= b.status %>">
                                                <%= b.status %>
                                            </span></td>
                                    </tr>
                                    <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <script>function filterTable(t, q) { document.getElementById(t).querySelectorAll('tbody tr').forEach(r => { r.style.display = r.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none' }); }</script>
        <%- include('../layouts/footer') %>