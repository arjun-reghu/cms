<%- include('../layouts/header') %>
    <%- include('../layouts/sidebar') %>

        <div class="page-header">
            <h2>Dashboard</h2>
            <p>Welcome back, <%= user.employee_name %>
            </p>
        </div>

        <div class="stats-grid">
            <div class="stat-card blue">
                <div class="stat-icon"><i class="fas fa-building"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= branchCount %>
                    </h3>
                    <p>Total Branches</p>
                </div>
            </div>
            <div class="stat-card cyan">
                <div class="stat-icon"><i class="fas fa-box"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= assetCount %>
                    </h3>
                    <p>Total Assets</p>
                </div>
            </div>
            <div class="stat-card yellow">
                <div class="stat-icon"><i class="fas fa-ticket-alt"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= openTickets %>
                    </h3>
                    <p>Pending Approvals</p>
                </div>
            </div>
            <div class="stat-card green">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= employeeCount %>
                    </h3>
                    <p>Total Employees</p>
                </div>
            </div>
            <div class="stat-card purple">
                <div class="stat-icon"><i class="fas fa-envelope"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= emailCount %>
                    </h3>
                    <p>Email Accounts</p>
                </div>
            </div>
            <div class="stat-card red">
                <div class="stat-icon"><i class="fas fa-user-shield"></i></div>
                <div class="stat-info">
                    <h3>
                        <%= adCount %>
                    </h3>
                    <p>AD Accounts</p>
                </div>
            </div>
        </div>

        <% if (expiringAgreements> 0) { %>
            <div class="card" style="border-left: 4px solid var(--warning);">
                <div class="card-header">
                    <span class="card-title"><i class="fas fa-exclamation-triangle" style="color: var(--warning);"></i>
                        Agreement Alerts</span>
                </div>
                <p style="color: var(--text-secondary);">
                    <%= expiringAgreements %> agreement(s) expiring within 30 days. <a href="/admin/agreements">View
                            Agreements</a>
                </p>
            </div>
            <% } %>

                <%- include('../layouts/footer') %>